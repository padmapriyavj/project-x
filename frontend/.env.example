# Copy to `.env` or `.env.local` in this folder and fill in values.
# Vite only exposes variables prefixed with `VITE_` to the client.
# Never commit real API keys — use `.env.local` (ignored via `*.local` in `.gitignore`).

# --- Backend (Person A) ---
# Base URL for FastAPI, no trailing slash (e.g. http://127.0.0.1:8000).
# If unset, auth uses local mocks unless VITE_AUTH_MOCK forces mocks.
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: Socket.IO HTTP origin when it is not the same as VITE_API_BASE_URL (quiz-room namespace).
# VITE_WS_BASE_URL=http://127.0.0.1:8000

# Optional: same URL you use for `npm run generate:api` when pointing at a live spec.
# VITE_OPENAPI_URL=http://127.0.0.1:8000/openapi.json

# Set to `true` to keep using mock auth while VITE_API_BASE_URL is set (UI testing).
# VITE_AUTH_MOCK=false

# --- ElevenLabs — PRD §8.1 (TTS + Conversational AI) ---
# Text-to-speech for Finn lines (Tempo, practice, duel, quiz reactions — PRD §7.4–§7.8).
# Browser calls REST API unless you use cached URLs below (§14.3 mitigations).
# VITE_ELEVENLABS_API_KEY=   # also used as dev `authorization` for Coach (@elevenlabs/client); prefer backend tokens in production.

# Optional voice id. If unset, a built-in sample id is used. Do not leave the key
# present with an empty value — Vite will set "" and the API path becomes /text-to-speech/ (404).
# VITE_ELEVENLABS_VOICE_ID=

# Optional Finn line TTS speed (1.0 = normal). Default in code is 1.1 if unset.
# VITE_ELEVENLABS_TTS_SPEED=1.15

# Coach session — Conversational AI agent (PRD §7.8). Required to start a browser session.
# VITE_ELEVENLABS_AGENT_ID=

# --- Cached Finn audio (PRD §14.3) ---
# Optional MP3/WAV URLs so demos do not hit TTS for every static line.
# VITE_FINN_GREETING_AUDIO_URL=
# VITE_VOICE_CACHE_FIRST_LOGIN_URL=
# VITE_VOICE_CACHE_BEFORE_TEMPO_URL=
# VITE_VOICE_CACHE_TEMPO_PING_URL=
# VITE_VOICE_CACHE_END_QUIZ_URL=
# VITE_VOICE_CACHE_DUEL_INTRO_URL=
# VITE_VOICE_CACHE_QUIZ_QUESTION_READ_URL=   # static clip; skips TTS for quiz question read when set
# VITE_VOICE_CACHE_WRONG_ANSWER_REFRAME_URL=
# VITE_VOICE_CACHE_DUEL_QUESTION_READ_URL=
# VITE_VOICE_CACHE_DUEL_PEER_COMMENTARY_URL=
# VITE_VOICE_CACHE_DUEL_WINNER_CALLOUT_URL=

# --- OpenAPI codegen (not read by Vite; for `npm run generate:api`) ---
# The script `scripts/generate-api.mjs` also reads `OPENAPI_URL` or `VITE_OPENAPI_URL`
# from the shell environment, e.g.:
#   OPENAPI_URL=http://127.0.0.1:8000/openapi.json npm run generate:api
